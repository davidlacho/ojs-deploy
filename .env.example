# Copy to .env (on your machine) to change defaults.
# GitHub Actions will generate a remote .env automatically from secrets.

TZ=Etc/UTC

# OJS image build arg:
# Use an official PKP tar.gz URL for the release you want.
# Example patterns (choose the one you want):
# - https://pkp.sfu.ca/ojs/download/ojs-3.5.0-0.tar.gz
# - https://pkp.sfu.ca/ojs/download/ojs-3.5.0-3.tar.gz
OJS_TARBALL_URL=https://pkp.sfu.ca/ojs/download/ojs-3.5.0-3.tar.gz

# MariaDB:
MARIADB_DATABASE=ojs
MARIADB_USER=ojs

# If you want to use HTTPS later:
ACME_EMAIL=
OJS_HOSTNAME=

# Optional: OJS base URL that you can use in your installer
# (Traefik base routing is host-based; for HTTP-only it’s HostRegexp)
OJS_BASE_URL=http://localhost

# Optional: auto-apply a journal theme at container startup (idempotent).
# Example:
# OJS_JOURNAL_PATH=joicac
# OJS_JOURNAL_THEME=bootstrap3
OJS_JOURNAL_PATH=
OJS_JOURNAL_THEME=

# Optional SMTP (mirrors GitHub secrets/vars; leave empty to skip).
# When OJS_SMTP_SERVER is set, container startup updates config.inc.php [email].
# OJS_SMTP_PORT=587
# OJS_SMTP_AUTH=tls
# OJS_SMTP_SERVER=
# OJS_SMTP_USERNAME=
# OJS_SMTP_PASSWORD=
# OJS_SMTP_DEFAULT_ENVELOPE_SENDER=
# OJS_SMTP_ALLOW_ENVELOPE_SENDER=On
# OJS_SMTP_FORCE_DEFAULT_ENVELOPE_SENDER=Off

